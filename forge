# --- Token commands ---

verify_token_http() {
  local token="$1"
  local result http_code
  result=$(curl -s -w '\n%{http_code}' -X GET \
    "$FORGE_URL/api/v1/user" \
    --config <(printf 'header = "Authorization: token %s"\n' "$token"))
  http_code=$(printf '%s' "$result" | tail -1)
  local body
  body=$(printf '%s' "$result" | sed '$d')
  VERIFY_HTTP_CODE="$http_code"
  VERIFY_LOGIN=""
  if [[ "$http_code" == "200" ]]; then
    VERIFY_LOGIN=$(printf '%s' "$body" | jq -r '.login')
  fi
}

token_verify() {
  contains_help_flag "$@" && { command_usage "token verify"; return; }
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*) die "unknown option for token verify: $1" ;;
      *) die "unexpected argument for token verify: $1" ;;
    esac
  done

  [[ ! -t 0 ]] || die "token verify reads from stdin; pipe a token to it"

  local verify_token
  verify_token=$(validate_token "$(cat)" "stdin")

  verify_token_http "$verify_token"
  if [[ "$VERIFY_HTTP_CODE" == "200" ]]; then
    echo "Token valid: authenticated as $VERIFY_LOGIN"
  else
    local reason
    case "$VERIFY_HTTP_CODE" in
      401) reason="unauthorized" ;;
      403) reason="forbidden" ;;
      *)   reason="HTTP $VERIFY_HTTP_CODE" ;;
    esac
    echo "Token invalid: $reason" >&2
    exit 1
  fi
}

# --- Auth commands ---

auth_status() {
  contains_help_flag "$@" && { command_usage "auth status"; return; }
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*) die "unknown option for auth status: $1" ;;
      *) die "unexpected argument for auth status: $1" ;;
    esac
  done

  load_token
  local source_desc
  if [ -n "${FORGEJO_TOKEN:-}" ]; then
    source_desc="FORGEJO_TOKEN"
  else
    source_desc="$FORGE_TOKEN_FILE"
  fi

  verify_token_http "$TOKEN"
  if [[ "$VERIFY_HTTP_CODE" == "200" ]]; then
    echo "Authenticated as $VERIFY_LOGIN ($source_desc)"
  else
    local reason
    case "$VERIFY_HTTP_CODE" in
      401) reason="unauthorized" ;;
      403) reason="forbidden" ;;
      *)   reason="HTTP $VERIFY_HTTP_CODE" ;;
    esac
    echo "Authentication failed: $reason ($source_desc)" >&2
    exit 1
  fi
}

