#!/usr/bin/env bash
# forge - Forgejo CLI, like gh but for Forgejo
#
# Usage: forge [-R|--repo owner/repo] <resource> <command> [args]
#
# Resources:  pr, issue, token, auth
#
# auth commands:
#   forge auth status                           Check configured credentials
#
# token commands:
#   forge token verify                          Verify a candidate token from stdin
#
# pr commands:
#   forge pr list                              List open pull requests
#   forge pr view <number>                     Show PR details and comments
#   forge pr review-comments <number>          List inline comments with IDs
#   forge pr reply <number> <id> --body <text> Reply to an inline comment thread
#   forge pr create --title <title> [flags]    Create a pull request
#   forge pr edit <number> [flags]             Edit a pull request
#   forge pr comment <number> --body <text>    Post a comment on a PR
#   forge pr close {<number>|<url>|<branch>} [flags]  Close a pull request
#
# issue commands:
#   forge issue list                            List open issues
#   forge issue view <number>                   Show issue details and comments
#   forge issue create --title <title> [flags]  Create an issue
#   forge issue edit <number> [flags]           Edit an issue
#   forge issue close <number-or-url> [flags]    Close an issue
#
# Config (env vars):
#   FORGE_URL          Base URL of Forgejo instance (default: https://forge.anarch.diy)
#   FORGEJO_TOKEN      API token (takes precedence over token file)
#   FORGE_TOKEN_FILE   Path to token file (default: ~/.config/git/forgejo-token)

set -euo pipefail

FORGE_URL="${FORGE_URL:-https://forge.anarch.diy}"
FORGE_TOKEN_FILE="${FORGE_TOKEN_FILE:-$HOME/.config/git/forgejo-token}"

# --- Helpers ---

urlencode() {
  printf '%s' "$1" | jq -sRr @uri
}

# --- Dependencies ---

if ! command -v jq &>/dev/null; then
  echo "forge: jq is required but not installed" >&2
  exit 1
fi
if ! command -v curl &>/dev/null; then
  echo "forge: curl is required but not installed" >&2
  exit 1
fi

# --- Auth ---

TOKEN=""
TOKEN_LOADED=false

validate_token() {
  local token="$1" source="$2"
  token="${token%$'\r'}"
  if [[ "$token" == *$'\n'* || "$token" == *'"'* || "$token" == *\\* ]]; then
    echo "forge: $source contains invalid characters (newline, quote, or backslash)" >&2
    exit 1
  fi
  [[ -n "$token" ]] || { echo "forge: $source is empty" >&2; exit 1; }
  printf '%s' "$token"
}

load_token() {
  [[ "$TOKEN_LOADED" == false ]] || return 0
  if [ -n "${FORGEJO_TOKEN:-}" ]; then
    TOKEN=$(validate_token "$FORGEJO_TOKEN" "FORGEJO_TOKEN")
  elif [ -r "$FORGE_TOKEN_FILE" ]; then
    TOKEN=$(validate_token "$(cat "$FORGE_TOKEN_FILE")" "$FORGE_TOKEN_FILE")
  else
    echo "forge: no token found — set FORGEJO_TOKEN or ensure $FORGE_TOKEN_FILE exists" >&2
    exit 1
  fi
  TOKEN_LOADED=true
}

# --- Repo inference ---

infer_repo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || {
    echo "forge: not in a git repo and --repo not specified" >&2
    exit 1
  }
  # Strip .git suffix, then extract last two path components (owner/repo)
  # Handles: ssh://git@host:port/owner/repo.git  git@host:owner/repo.git  https://host/owner/repo.git
  url="${url%.git}"
  echo "$url" | grep -oE '[^/:]+/[^/:]+$'
}

# --- Arg parsing ---

REPO=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -R|--repo)
      [[ $# -ge 2 ]] || {
        echo "forge: $1 requires a value" >&2
        exit 1
      }
      REPO="$2"
      shift 2
      ;;
    -h|--help) RESOURCE="help"; shift ;;
    *) break ;;
  esac
done

RESOURCE="${1:-help}"; [[ $# -gt 0 ]] && shift
COMMAND="${1:-}";       [[ $# -gt 0 ]] && shift

require_repo() {
  [ -n "$REPO" ] || REPO=$(infer_repo)
}

die() {
  echo "forge: $*" >&2
  exit 1
}

contains_help_flag() {
  for arg in "$@"; do
    case "$arg" in
      -h|--help) return 0 ;;
    esac
  done
  return 1
}

require_option_value() {
  local option="$1"
  local count="$2"
  [[ "$count" -ge 2 ]] || die "$option requires a value"
}

set_repo_option() {
  local option="$1"
  require_option_value "$option" "$#"
  REPO="$2"
}

parse_repo_only_args() {
  local context="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -*) die "unknown option for $context: $1" ;;
      *) die "unexpected argument for $context: $1" ;;
    esac
  done
}

POSITIONAL_ARGS=()
parse_repo_positionals() {
  local context="$1"
  shift
  POSITIONAL_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -*) die "unknown option for $context: $1" ;;
      *)
        POSITIONAL_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

reset_body_option() {
  BODY=""
  BODY_SET=false
  BODY_SOURCE=""
}

set_body_option() {
  local option="$1"
  local value="$2"
  [[ "$BODY_SET" == false ]] || {
    die "$option cannot be combined with $BODY_SOURCE"
  }

  if [[ "$option" == "-F" || "$option" == "--body-file" ]]; then
    if [[ "$value" != "-" && ! -r "$value" ]]; then
      die "cannot read body file: $value"
    fi
    local body_with_sentinel
    if [[ "$value" == "-" ]]; then
      body_with_sentinel="$(cat; printf '\x1f')"
    else
      body_with_sentinel="$(cat "$value"; printf '\x1f')"
    fi
    BODY="${body_with_sentinel%?}"
  else
    BODY="$value"
  fi

  BODY_SET=true
  BODY_SOURCE="$option"
}

# --- API helper ---

api() {
  load_token
  local method="$1"; shift
  local path="$1"; shift
  curl -sf -X "$method" \
    "$FORGE_URL/api/v1$path" \
    --config <(printf 'header = "Authorization: token %s"\n' "$TOKEN") \
    -H "Content-Type: application/json" \
    "$@"
}

# --- PR commands ---

pr_list() {
  contains_help_flag "$@" && { command_usage "pr list"; return; }
  parse_repo_only_args "pr list" "$@"
  require_repo
  local result
  result=$(api GET "/repos/$REPO/pulls?state=open&limit=50")
  local count
  count=$(echo "$result" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No open pull requests in $REPO"
    return
  fi
  echo "$result" | jq -r '.[] | "\(.number)\t\(.title)\t\(.user.login)\t\(.head.label) → \(.base.label)"' \
    | column -t -s $'\t'
}

pr_view() {
  contains_help_flag "$@" && { command_usage "pr view"; return; }
  parse_repo_positionals "pr view" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge pr view <number>"
  require_repo
  local number="${POSITIONAL_ARGS[0]}"
  local pr comments reviews

  pr=$(api GET "/repos/$REPO/pulls/$number")
  comments=$(api GET "/repos/$REPO/issues/$number/comments")
  reviews=$(api GET "/repos/$REPO/pulls/$number/reviews")

  local title state author head base
  title=$(echo "$pr" | jq -r '.title')
  state=$(echo "$pr" | jq -r '.state')
  author=$(echo "$pr" | jq -r '.user.login')
  head=$(echo "$pr" | jq -r '.head.label')
  base=$(echo "$pr" | jq -r '.base.label')

  echo "PR #$number: $title"
  echo "  State:  $state"
  echo "  Author: $author"
  echo "  Branch: $head → $base"
  echo ""

  local body
  body=$(echo "$pr" | jq -r '.body // ""')
  if [ -n "$body" ]; then
    echo "$body"
    echo ""
  fi

  local count
  count=$(echo "$comments" | jq 'length')
  if [ "$count" -gt 0 ]; then
    echo "--- $count comment(s) ---"
    echo "$comments" | jq -r '.[] | "[\(.created_at[:10])] \(.user.login):\n\(.body)\n"'
  fi

  local review_ids
  review_ids=$(echo "$reviews" | jq -r '.[] | select(.comments_count > 0) | .id')
  if [ -n "$review_ids" ]; then
    local total_inline=0
    local inline_output=""
    while IFS= read -r rid; do
      local rc
      rc=$(api GET "/repos/$REPO/pulls/$number/reviews/$rid/comments")
      local rc_count
      rc_count=$(echo "$rc" | jq 'length')
      total_inline=$((total_inline + rc_count))
      inline_output+=$(echo "$rc" | jq -r '.[] | "[\(.created_at[:10])] \(.user.login) on \(.path) line \(.line // "?"):\n\(.diff_hunk)\n> \(.body)\n"')
      inline_output+=$'\n'
    done <<< "$review_ids"
    if [ "$total_inline" -gt 0 ]; then
      echo "--- $total_inline inline comment(s) ---"
      printf '%s\n' "$inline_output"
    fi
  fi
}

pr_review_comments() {
  contains_help_flag "$@" && { command_usage "pr review-comments"; return; }
  parse_repo_positionals "pr review-comments" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge pr review-comments <number>"
  require_repo
  local number="${POSITIONAL_ARGS[0]}"
  local reviews review_ids
  reviews=$(api GET "/repos/$REPO/pulls/$number/reviews")
  review_ids=$(echo "$reviews" | jq -r '.[] | select(.comments_count > 0) | .id')

  if [ -z "$review_ids" ]; then
    echo "No inline comments on PR #$number"
    return
  fi

  while IFS= read -r rid; do
    local rc
    rc=$(api GET "/repos/$REPO/pulls/$number/reviews/$rid/comments")
    echo "$rc" | jq -r '.[] | "id \(.id) [\(.created_at[:10])] \(.user.login) on \(.path) line \(.line // "?"):\n\(.diff_hunk)\n> \(.body)\n"'
  done <<< "$review_ids"
}

pr_edit() {
  contains_help_flag "$@" && { command_usage "pr edit"; return; }
  local number="" number_set=false
  local title="" title_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr edit: $1" ;;
      *)
        [[ "$number_set" == false ]] || die "unexpected argument for pr edit: $1"
        number="$1"
        number_set=true
        shift
        ;;
    esac
  done

  [[ "$number_set" == true && -n "$number" ]] || {
    die "usage: forge pr edit <number> [--title <title>] [--body <text> | --body-file <file>]"
  }
  [[ "$title_set" == true || "$BODY_SET" == true ]] || {
    die "pr edit requires --title, --body, or --body-file"
  }
  [[ "$title_set" == false || -n "$title" ]] || die "--title cannot be empty"
  require_repo

  local payload
  payload=$(jq -n \
    --arg title "$title" \
    --arg body "$BODY" \
    --argjson title_set "$title_set" \
    --argjson body_set "$BODY_SET" \
    '{} | if $title_set then . + {title: $title} else . end
        | if $body_set  then . + {body: $body}  else . end')
  local url
  url=$(api PATCH "/repos/$REPO/pulls/$number" -d "$payload" | jq -r '.html_url')
  echo "PR updated: $url"
}

pr_comment() {
  contains_help_flag "$@" && { command_usage "pr comment"; return; }
  local number="" number_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr comment: $1" ;;
      *)
        [[ "$number_set" == false ]] || die "unexpected argument for pr comment: $1"
        number="$1"
        number_set=true
        shift
        ;;
    esac
  done
  [[ "$number_set" == true && -n "$number" ]] || {
    die "usage: forge pr comment <number> [--body <text> | --body-file <file>]"
  }
  [[ "$BODY_SET" == true ]] || die "pr comment requires --body or --body-file"
  require_repo

  local url
  url=$(api POST "/repos/$REPO/issues/$number/comments" \
    -d "$(jq -n --arg body "$BODY" '{body: $body}')" | jq -r '.html_url')
  echo "Comment posted: $url"
}

pr_reply() {
  contains_help_flag "$@" && { command_usage "pr reply"; return; }
  local number="" number_set=false
  local comment_id="" comment_id_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr reply: $1" ;;
      *)
        if [[ "$number_set" == false ]]; then
          number="$1"
          number_set=true
        elif [[ "$comment_id_set" == false ]]; then
          comment_id="$1"
          comment_id_set=true
        else
          die "unexpected argument for pr reply: $1"
        fi
        shift
        ;;
    esac
  done
  [[ "$number_set" == true && "$comment_id_set" == true && -n "$number" && -n "$comment_id" ]] || {
    die "usage: forge pr reply <number> <comment-id> [--body <text> | --body-file <file>]"
  }
  [[ "$BODY_SET" == true ]] || die "pr reply requires --body or --body-file"
  require_repo

  # Find the review containing the original comment.
  # Replies must go to POST /reviews/{id}/comments — posting to a new review
  # doesn't thread correctly regardless of path/position/in_reply_to fields.
  local reviews review_ids orig_review_id="" orig_path="" orig_position=0
  reviews=$(api GET "/repos/$REPO/pulls/$number/reviews")
  review_ids=$(echo "$reviews" | jq -r '.[] | select(.comments_count > 0) | .id')

  while IFS= read -r rid; do
    local rc match
    rc=$(api GET "/repos/$REPO/pulls/$number/reviews/$rid/comments")
    match=$(echo "$rc" | jq -r --argjson cid "$comment_id" 'first(.[] | select(.id == $cid)) // empty')
    if [ -n "$match" ]; then
      orig_review_id="$rid"
      orig_path=$(echo "$match"     | jq -r '.path')
      orig_position=$(echo "$match" | jq -r '.position // 0')
      break
    fi
  done <<< "$review_ids"

  # TODO: starting a new inline thread (no existing comment to reply to) requires
  # POST /reviews with a comment containing path + new_position. Add a
  # `forge pr inline <number> <path> <line> <body>` command when agentic review is needed.

  if [ -z "$orig_review_id" ]; then
    echo "forge: comment $comment_id not found on PR #$number" >&2
    exit 1
  fi

  local url
  url=$(api POST "/repos/$REPO/pulls/$number/reviews/$orig_review_id/comments" \
    -d "$(jq -n \
      --arg path "$orig_path" \
      --argjson new_position "$orig_position" \
      --arg body "$BODY" \
      '{path: $path, new_position: $new_position, body: $body}')" \
    | jq -r '.html_url')
  echo "Reply posted: $url"
}

pr_create() {
  contains_help_flag "$@" && { command_usage "pr create"; return; }
  local title="" head="" base=""
  local title_set=false head_set=false base_set=false
  reset_body_option

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -H|--head)
        require_option_value "$1" "$#"
        [[ "$head_set" == false ]] || die "$1 specified more than once"
        head="$2"
        head_set=true
        shift 2
        ;;
      -B|--base)
        require_option_value "$1" "$#"
        [[ "$base_set" == false ]] || die "$1 specified more than once"
        base="$2"
        base_set=true
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr create: $1" ;;
      *) die "unexpected argument for pr create: $1" ;;
    esac
  done

  [[ "$title_set" == true ]] || die "pr create requires --title"
  [[ -n "$title" ]] || die "--title cannot be empty"
  [[ "$head_set" == false || -n "$head" ]] || die "--head cannot be empty"
  [[ "$base_set" == false || -n "$base" ]] || die "--base cannot be empty"
  require_repo

  if [[ "$head_set" == false ]]; then
    head=$(git branch --show-current 2>/dev/null || true)
    [[ -n "$head" ]] || {
      die "cannot infer PR head branch; use --head"
    }
  fi

  if [[ "$base_set" == false ]]; then
    base=$(api GET "/repos/$REPO" | jq -r '.default_branch // empty')
    [[ -n "$base" ]] || {
      die "could not determine repository default branch; use --base"
    }
  fi

  local url
  url=$(api POST "/repos/$REPO/pulls" \
    -d "$(jq -n \
      --arg title "$title" \
      --arg head "$head" \
      --arg base "$base" \
      --arg body "$BODY" \
      '{title: $title, head: $head, base: $base, body: $body}')" \
    | jq -r '.html_url')
  echo "PR created: $url"
}

pr_find_by_head() {
  contains_help_flag "$@" && { command_usage "pr find-by-head"; return; }
  parse_repo_positionals "pr find-by-head" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge pr find-by-head <branch>"
  require_repo
  local head_branch="${POSITIONAL_ARGS[0]}"
  # Prints the PR number if an open PR exists for this head branch; prints nothing if not found.
  api GET "/repos/$REPO/pulls?state=open&limit=50&head=$(urlencode "$head_branch")" \
    | jq -r 'first(.[] | .number) // empty'
}

resolve_pr_target() {
  local target="$1"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    require_repo
    PR_NUMBER="$target"
    return
  fi

  local base="${FORGE_URL%/}"
  if [[ "$target" == https://* || "$target" == http://* ]]; then
    case "$target" in
      "$base"/*)
        local path="${target#"$base"/}"
        local owner repo resource number extra
        IFS=/ read -r owner repo resource number extra <<< "$path"
        [[ -n "$owner" && -n "$repo" && "$resource" == "pulls" &&
           "$number" =~ ^[0-9]+$ && -z "$extra" ]] || {
          die "PR target must be a number, URL on $base, or branch name"
        }
        REPO="$owner/$repo"
        PR_NUMBER="$number"
        ;;
      *) die "PR target must be a number, URL on $base, or branch name" ;;
    esac
    return
  fi

  require_repo
  PR_NUMBER=$(api GET "/repos/$REPO/pulls?state=open&limit=50&head=$(urlencode "$target")" \
    | jq -r 'first(.[] | .number) // empty')
  [[ -n "$PR_NUMBER" ]] || die "no open PR found for branch: $target"
}

pr_close() {
  contains_help_flag "$@" && { command_usage "pr close"; return; }
  local target="" target_set=false
  local comment="" comment_set=false
  local delete_branch=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -c|--comment)
        require_option_value "$1" "$#"
        [[ "$comment_set" == false ]] || die "$1 specified more than once"
        comment="$2"
        [[ -n "$comment" ]] || die "--comment cannot be empty"
        comment_set=true
        shift 2
        ;;
      -d|--delete-branch)
        delete_branch=true
        shift
        ;;
      -*) die "unknown option for pr close: $1" ;;
      *)
        [[ "$target_set" == false ]] || die "unexpected argument for pr close: $1"
        target="$1"
        target_set=true
        shift
        ;;
    esac
  done

  [[ "$target_set" == true && -n "$target" ]] || {
    die "usage: forge pr close {<number> | <url> | <branch>} [-c <text>] [-d] [-R <owner/repo>]"
  }

  resolve_pr_target "$target"

  if [[ "$comment_set" == true ]]; then
    api POST "/repos/$REPO/issues/$PR_NUMBER/comments" \
      -d "$(jq -n --arg body "$comment" '{body: $body}')" >/dev/null
  fi

  local head_ref=""
  if [[ "$delete_branch" == true ]]; then
    local pr_data
    pr_data=$(api GET "/repos/$REPO/pulls/$PR_NUMBER")
    head_ref=$(echo "$pr_data" | jq -r '.head.ref')
    local base_ref
    base_ref=$(echo "$pr_data" | jq -r '.base.ref')
    if [[ "$head_ref" == "$base_ref" ]]; then
      echo "forge: warning: not deleting branch $head_ref (same as base branch)" >&2
      delete_branch=false
    fi
  fi

  local url
  url=$(api PATCH "/repos/$REPO/pulls/$PR_NUMBER" \
    -d '{"state":"closed"}' | jq -r '.html_url')

  if [[ "$delete_branch" == true && -n "$head_ref" ]]; then
    if api DELETE "/repos/$REPO/branches/$(urlencode "$head_ref")" >/dev/null 2>&1; then
      echo "PR closed: $url (branch $head_ref deleted)"
    else
      echo "PR closed: $url"
      echo "forge: warning: failed to delete branch $head_ref" >&2
    fi
  else
    echo "PR closed: $url"
  fi
}

# --- Issue commands ---

issue_list() {
  contains_help_flag "$@" && { command_usage "issue list"; return; }
  parse_repo_only_args "issue list" "$@"
  require_repo
  local result
  result=$(api GET "/repos/$REPO/issues?type=issues&state=open&limit=50")
  local count
  count=$(echo "$result" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No open issues in $REPO"
    return
  fi
  echo "$result" | jq -r '.[] | "\(.number)\t\(.title)\t\(.user.login)"' \
    | column -t -s $'\t'
}

issue_view() {
  contains_help_flag "$@" && { command_usage "issue view"; return; }
  parse_repo_positionals "issue view" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge issue view <number>"
  require_repo
  local number="${POSITIONAL_ARGS[0]}"
  local issue comments

  issue=$(api GET "/repos/$REPO/issues/$number")
  comments=$(api GET "/repos/$REPO/issues/$number/comments")

  local title state author
  title=$(echo "$issue" | jq -r '.title')
  state=$(echo "$issue" | jq -r '.state')
  author=$(echo "$issue" | jq -r '.user.login')

  echo "Issue #$number: $title"
  echo "  State:  $state"
  echo "  Author: $author"
  echo ""

  local body
  body=$(echo "$issue" | jq -r '.body // ""')
  if [ -n "$body" ]; then
    echo "$body"
    echo ""
  fi

  local count
  count=$(echo "$comments" | jq 'length')
  if [ "$count" -gt 0 ]; then
    echo "--- $count comment(s) ---"
    echo "$comments" | jq -r '.[] | "[\(.created_at[:10])] \(.user.login):\n\(.body)\n"'
  fi
}

issue_create() {
  contains_help_flag "$@" && { command_usage "issue create"; return; }
  local title="" title_set=false
  reset_body_option

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for issue create: $1" ;;
      *) die "unexpected argument for issue create: $1" ;;
    esac
  done

  [[ "$title_set" == true ]] || die "issue create requires --title"
  [[ -n "$title" ]] || die "--title cannot be empty"
  require_repo

  local url
  url=$(api POST "/repos/$REPO/issues" \
    -d "$(jq -n \
      --arg title "$title" \
      --arg body "$BODY" \
      '{title: $title, body: $body}')" \
    | jq -r '.html_url')
  echo "Issue created: $url"
}

issue_edit() {
  contains_help_flag "$@" && { command_usage "issue edit"; return; }
  local number="" number_set=false
  local title="" title_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for issue edit: $1" ;;
      *)
        [[ "$number_set" == false ]] || die "unexpected argument for issue edit: $1"
        number="$1"
        number_set=true
        shift
        ;;
    esac
  done

  [[ "$number_set" == true && -n "$number" ]] || {
    die "usage: forge issue edit <number> [--title <title>] [--body <text> | --body-file <file>]"
  }
  [[ "$title_set" == true || "$BODY_SET" == true ]] || {
    die "issue edit requires --title, --body, or --body-file"
  }
  [[ "$title_set" == false || -n "$title" ]] || die "--title cannot be empty"
  require_repo

  local payload
  payload=$(jq -n \
    --arg title "$title" \
    --arg body "$BODY" \
    --argjson title_set "$title_set" \
    --argjson body_set "$BODY_SET" \
    '{} | if $title_set then . + {title: $title} else . end
        | if $body_set  then . + {body: $body}  else . end')
  local url
  url=$(api PATCH "/repos/$REPO/issues/$number" -d "$payload" | jq -r '.html_url')
  echo "Issue updated: $url"
}

resolve_issue_target() {
  local target="$1"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    require_repo
    ISSUE_NUMBER="$target"
    return
  fi

  local base="${FORGE_URL%/}"
  local path
  case "$target" in
    "$base"/*) path="${target#"$base"/}" ;;
    *) die "issue target must be a number or URL on $base" ;;
  esac

  local owner repo resource number extra
  IFS=/ read -r owner repo resource number extra <<< "$path"
  [[ -n "$owner" && -n "$repo" && "$resource" == "issues" &&
     "$number" =~ ^[0-9]+$ && -z "$extra" ]] || {
    die "issue target must be a number or URL on $base"
  }

  REPO="$owner/$repo"
  ISSUE_NUMBER="$number"
}

normalize_issue_reference() {
  local target="$1"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    printf '#%s' "$target"
    return
  fi

  local base="${FORGE_URL%/}"
  local path
  case "$target" in
    "$base"/*) path="${target#"$base"/}" ;;
    *) die "duplicate target must be a number or URL on $base" ;;
  esac

  local owner repo resource number extra
  IFS=/ read -r owner repo resource number extra <<< "$path"
  [[ -n "$owner" && -n "$repo" && "$resource" == "issues" &&
     "$number" =~ ^[0-9]+$ && -z "$extra" ]] || {
    die "duplicate target must be a number or URL on $base"
  }
  printf '%s' "$target"
}

issue_close() {
  contains_help_flag "$@" && { command_usage "issue close"; return; }
  local target="" target_set=false
  local comment="" reason="" duplicate_of=""
  local comment_set=false reason_set=false duplicate_set=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -c|--comment)
        require_option_value "$1" "$#"
        [[ "$comment_set" == false ]] || die "$1 specified more than once"
        comment="$2"
        comment_set=true
        shift 2
        ;;
      -r|--reason)
        require_option_value "$1" "$#"
        [[ "$reason_set" == false ]] || die "$1 specified more than once"
        reason="$2"
        reason_set=true
        shift 2
        ;;
      --duplicate-of)
        require_option_value "$1" "$#"
        [[ "$duplicate_set" == false ]] || die "$1 specified more than once"
        duplicate_of="$2"
        duplicate_set=true
        shift 2
        ;;
      -*) die "unknown option for issue close: $1" ;;
      *)
        [[ "$target_set" == false ]] || die "unexpected argument for issue close: $1"
        target="$1"
        target_set=true
        shift
        ;;
    esac
  done

  [[ "$target_set" == true && -n "$target" ]] || {
    die "usage: forge issue close {<number> | <url>} [--comment <text>] [--reason <reason>] [--duplicate-of <issue>]"
  }

  if [[ "$reason_set" == true ]]; then
    case "$reason" in
      completed|"not planned"|duplicate) ;;
      *) die "--reason must be one of: completed, not planned, duplicate" ;;
    esac
  elif [[ "$duplicate_set" == true ]]; then
    reason="duplicate"
  else
    reason="completed"
  fi

  if [[ "$duplicate_set" == true && "$reason_set" == true && "$reason" != duplicate ]]; then
    die "--duplicate-of cannot be combined with --reason $reason"
  fi
  [[ "$duplicate_set" == false || -n "$duplicate_of" ]] || die "--duplicate-of cannot be empty"

  resolve_issue_target "$target"

  local reason_note=""
  case "$reason" in
    "not planned")
      reason_note="Closed as not planned."
      ;;
    duplicate)
      if [[ "$duplicate_set" == true ]]; then
        reason_note="Duplicate of $(normalize_issue_reference "$duplicate_of")."
      else
        reason_note="Closed as duplicate."
      fi
      ;;
  esac

  local closing_comment="$comment"
  if [[ -n "$reason_note" ]]; then
    if [[ "$comment_set" == true && -n "$closing_comment" ]]; then
      closing_comment+=$'\n\n'
    fi
    closing_comment+="$reason_note"
  fi

  if [[ "$comment_set" == true || -n "$reason_note" ]]; then
    api POST "/repos/$REPO/issues/$ISSUE_NUMBER/comments" \
      -d "$(jq -n --arg body "$closing_comment" '{body: $body}')" >/dev/null
  fi

  local url
  url=$(api PATCH "/repos/$REPO/issues/$ISSUE_NUMBER" \
    -d '{"state":"closed"}' | jq -r '.html_url')
  echo "Issue closed: $url"
}

# --- Token commands ---

verify_token_http() {
  local token="$1"
  local result http_code
  result=$(curl -s -w '\n%{http_code}' -X GET \
    "$FORGE_URL/api/v1/user" \
    --config <(printf 'header = "Authorization: token %s"\n' "$token"))
  http_code=$(printf '%s' "$result" | tail -1)
  local body
  body=$(printf '%s' "$result" | sed '$d')
  VERIFY_HTTP_CODE="$http_code"
  VERIFY_LOGIN=""
  if [[ "$http_code" == "200" ]]; then
    VERIFY_LOGIN=$(printf '%s' "$body" | jq -r '.login')
  fi
}

token_verify() {
  contains_help_flag "$@" && { command_usage "token verify"; return; }
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*) die "unknown option for token verify: $1" ;;
      *) die "unexpected argument for token verify: $1" ;;
    esac
  done

  [[ ! -t 0 ]] || die "token verify reads from stdin; pipe a token to it"

  local verify_token
  verify_token=$(validate_token "$(cat)" "stdin")

  verify_token_http "$verify_token"
  if [[ "$VERIFY_HTTP_CODE" == "200" ]]; then
    echo "Token valid: authenticated as $VERIFY_LOGIN"
  else
    local reason
    case "$VERIFY_HTTP_CODE" in
      401) reason="unauthorized" ;;
      403) reason="forbidden" ;;
      *)   reason="HTTP $VERIFY_HTTP_CODE" ;;
    esac
    echo "Token invalid: $reason" >&2
    exit 1
  fi
}

# --- Auth commands ---

auth_status() {
  contains_help_flag "$@" && { command_usage "auth status"; return; }
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*) die "unknown option for auth status: $1" ;;
      *) die "unexpected argument for auth status: $1" ;;
    esac
  done

  load_token
  local source_desc
  if [ -n "${FORGEJO_TOKEN:-}" ]; then
    source_desc="FORGEJO_TOKEN"
  else
    source_desc="$FORGE_TOKEN_FILE"
  fi

  verify_token_http "$TOKEN"
  if [[ "$VERIFY_HTTP_CODE" == "200" ]]; then
    echo "Authenticated as $VERIFY_LOGIN ($source_desc)"
  else
    local reason
    case "$VERIFY_HTTP_CODE" in
      401) reason="unauthorized" ;;
      403) reason="forbidden" ;;
      *)   reason="HTTP $VERIFY_HTTP_CODE" ;;
    esac
    echo "Authentication failed: $reason ($source_desc)" >&2
    exit 1
  fi
}

