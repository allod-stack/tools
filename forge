issue_labels() {
  contains_help_flag "$@" && { command_usage "issue labels"; return; }
  local number="" number_set=false clear=false
  local add_labels=() remove_labels=() set_labels=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      --add)
        require_option_value "$1" "$#"
        [[ -n "$2" ]] || die "--add cannot be empty"
        add_labels+=("$2")
        shift 2
        ;;
      --remove)
        require_option_value "$1" "$#"
        [[ -n "$2" ]] || die "--remove cannot be empty"
        remove_labels+=("$2")
        shift 2
        ;;
      --set)
        require_option_value "$1" "$#"
        [[ -n "$2" ]] || die "--set cannot be empty"
        set_labels+=("$2")
        shift 2
        ;;
      --clear)
        clear=true
        shift
        ;;
      -*) die "unknown option for issue labels: $1" ;;
      *)
        [[ "$number_set" == false ]] || die "unexpected argument for issue labels: $1"
        number="$1"
        number_set=true
        shift
        ;;
    esac
  done

  [[ "$number_set" == true && -n "$number" ]] || {
    die "usage: forge issue labels <number> [--add <label>] [--remove <label>] [--set <label>] [--clear]"
  }
  if [[ "$clear" == true && ( "${#add_labels[@]}" -gt 0 || "${#remove_labels[@]}" -gt 0 || "${#set_labels[@]}" -gt 0 ) ]]; then
    die "--clear cannot be combined with label changes"
  fi
  if [[ "${#set_labels[@]}" -gt 0 && ( "${#add_labels[@]}" -gt 0 || "${#remove_labels[@]}" -gt 0 ) ]]; then
    die "--set cannot be combined with --add or --remove"
  fi
  require_repo

  local labels
  if [[ "$clear" == true ]]; then
    api DELETE "/repos/$REPO/issues/$number/labels" >/dev/null
    labels="[]"
  elif [[ "${#set_labels[@]}" -gt 0 ]]; then
    labels=$(api PUT "/repos/$REPO/issues/$number/labels" \
      -d "$(jq -n --argjson labels "$(json_mixed_label_array_from_args "${set_labels[@]}")" '{labels: $labels}')")
  else
    if [[ "${#add_labels[@]}" -gt 0 ]]; then
      labels=$(api POST "/repos/$REPO/issues/$number/labels" \
        -d "$(jq -n --argjson labels "$(json_mixed_label_array_from_args "${add_labels[@]}")" '{labels: $labels}')")
    fi
    local label
    for label in "${remove_labels[@]}"; do
      api DELETE "/repos/$REPO/issues/$number/labels/$(urlencode "$label")" >/dev/null
    done
    if [[ "${#remove_labels[@]}" -gt 0 || "${#add_labels[@]}" -eq 0 ]]; then
      labels=$(api GET "/repos/$REPO/issues/$number/labels")
    fi
  fi

  echo "Issue #$number labels: $(echo "$labels" | format_labels)"
}

issue_milestone() {
