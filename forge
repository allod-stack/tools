  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge label delete <id-or-name>"
  require_repo
  local target="${POSITIONAL_ARGS[0]}"
  local id
  id=$(resolve_label_id "$target")
  api DELETE "/repos/$REPO/labels/$id" >/dev/null
  echo "Label deleted: $target"
}

# --- Milestone commands ---

parse_milestone_state() {
  local state="$1"
  case "$state" in
    open|closed|all) printf '%s' "$state" ;;
    *) die "--state must be one of: open, closed, all" ;;
  esac
}

milestone_list() {
  contains_help_flag "$@" && { command_usage "milestone list"; return; }
  local state="open"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -s|--state)
        require_option_value "$1" "$#"
        state=$(parse_milestone_state "$2")
        shift 2
        ;;
      -*) die "unknown option for milestone list: $1" ;;
      *) die "unexpected argument for milestone list: $1" ;;
    esac
  done

  require_repo
  local result count
  result=$(api GET "/repos/$REPO/milestones?state=$state&limit=100")
  count=$(echo "$result" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    if [[ "$state" == all ]]; then
      echo "No milestones in $REPO"
    else
      echo "No $state milestones in $REPO"
    fi
    return
  fi
  echo "$result" | jq -r '.[] |
    "\(.id)\t\(.title)\t\(.state)\t\(.open_issues // 0)\t\(.closed_issues // 0)\t\((.due_on // "")[0:10])"' \
    | column -t -s $'\t'
}

milestone_view() {
  contains_help_flag "$@" && { command_usage "milestone view"; return; }
  parse_repo_positionals "milestone view" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge milestone view <id-or-title>"
  require_repo
  local id milestone
  id=$(resolve_milestone_id "${POSITIONAL_ARGS[0]}")
  milestone=$(api GET "/repos/$REPO/milestones/$id")
  echo "$milestone" | jq -r '"Milestone #\(.id): \(.title)
  State:  \(.state)
  Open:   \(.open_issues // 0)
  Closed: \(.closed_issues // 0)
  Due:    \((.due_on // "-")[0:10])

\(.description // "")"'
}

milestone_create() {
  contains_help_flag "$@" && { command_usage "milestone create"; return; }
  local title="" description="" due_on="" state=""
  local title_set=false description_set=false due_set=false state_set=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -d|--description)
        require_option_value "$1" "$#"
        [[ "$description_set" == false ]] || die "$1 specified more than once"
        description="$2"
        description_set=true
        shift 2
        ;;
      --due)
        require_option_value "$1" "$#"
        due_on=$(normalize_due_on "$2")
        due_set=true
        shift 2
        ;;
      -s|--state)
        require_option_value "$1" "$#"
        state=$(parse_milestone_state "$2")
        [[ "$state" != all ]] || die "--state for milestone create must be open or closed"
        state_set=true
        shift 2
        ;;
      -*) die "unknown option for milestone create: $1" ;;
      *) die "unexpected argument for milestone create: $1" ;;
    esac
  done

  [[ "$title_set" == true ]] || die "milestone create requires --title"
  [[ -n "$title" ]] || die "--title cannot be empty"
  require_repo

  local milestone
  milestone=$(api POST "/repos/$REPO/milestones" \
    -d "$(jq -n \
      --arg title "$title" \
      --arg description "$description" \
      --arg due_on "$due_on" \
      --arg state "$state" \
      --argjson description_set "$description_set" \
      --argjson due_set "$due_set" \
      --argjson state_set "$state_set" \
      '{title: $title}
        | if $description_set then . + {description: $description} else . end
        | if $due_set then . + {due_on: $due_on} else . end
        | if $state_set then . + {state: $state} else . end')")
  echo "$milestone" | jq -r '"Milestone created: \(.id) \(.title)"'
}

milestone_edit() {
  contains_help_flag "$@" && { command_usage "milestone edit"; return; }
  local target="" target_set=false
  local title="" description="" due_on="" state=""
  local title_set=false description_set=false due_set=false state_set=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -d|--description)
        require_option_value "$1" "$#"
        [[ "$description_set" == false ]] || die "$1 specified more than once"
        description="$2"
        description_set=true
        shift 2
        ;;
      --due)
        require_option_value "$1" "$#"
        due_on=$(normalize_due_on "$2")
        due_set=true
        shift 2
        ;;
      -s|--state)
        require_option_value "$1" "$#"
        state=$(parse_milestone_state "$2")
        [[ "$state" != all ]] || die "--state for milestone edit must be open or closed"
        state_set=true
        shift 2
        ;;
      -*) die "unknown option for milestone edit: $1" ;;
      *)
        [[ "$target_set" == false ]] || die "unexpected argument for milestone edit: $1"
        target="$1"
        target_set=true
        shift
        ;;
    esac
  done

  [[ "$target_set" == true && -n "$target" ]] || {
    die "usage: forge milestone edit <id-or-title> [--title <title>] [--description <text>] [--due <date>] [--state open|closed]"
  }
  [[ "$title_set" == true || "$description_set" == true || "$due_set" == true || "$state_set" == true ]] || die "milestone edit requires a change"
  [[ "$title_set" == false || -n "$title" ]] || die "--title cannot be empty"
  require_repo

  local id milestone
  id=$(resolve_milestone_id "$target")
  milestone=$(api PATCH "/repos/$REPO/milestones/$id" \
    -d "$(jq -n \
      --arg title "$title" \
      --arg description "$description" \
      --arg due_on "$due_on" \
      --arg state "$state" \
      --argjson title_set "$title_set" \
      --argjson description_set "$description_set" \
      --argjson due_set "$due_set" \
      --argjson state_set "$state_set" \
      '{} | if $title_set then . + {title: $title} else . end
          | if $description_set then . + {description: $description} else . end
          | if $due_set then . + {due_on: $due_on} else . end
          | if $state_set then . + {state: $state} else . end')")
  echo "$milestone" | jq -r '"Milestone updated: \(.id) \(.title)"'
}

milestone_delete() {
  contains_help_flag "$@" && { command_usage "milestone delete"; return; }
  parse_repo_positionals "milestone delete" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge milestone delete <id-or-title>"
  require_repo
  local target="${POSITIONAL_ARGS[0]}"
  local id
  id=$(resolve_milestone_id "$target")
  api DELETE "/repos/$REPO/milestones/$id" >/dev/null
  echo "Milestone deleted: $target"
}

