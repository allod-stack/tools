          | if $description_set then . + {description: $description} else . end
          | if $exclusive_set then . + {exclusive: $exclusive} else . end
          | if $archived_set then . + {is_archived: $archived} else . end')")
  echo "$label" | jq -r '"Label updated: \(.id) \(.name)"'
}

label_delete() {
  contains_help_flag "$@" && { command_usage "label delete"; return; }
