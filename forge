#!/usr/bin/env bash
# forge - Forgejo CLI, like gh but for Forgejo
#
# Usage: forge [-R owner/repo] <resource> <command> [args]
#
# Resources:  pr, issue
#
# pr commands:
#   forge pr list                              List open pull requests
#   forge pr view <number>                     Show PR details and comments
#   forge pr review-comments <number>          List inline comments with IDs
#   forge pr reply <number> <id> --body <text> Reply to an inline comment thread
#   forge pr create --title <title> [flags]    Create a pull request
#   forge pr edit <number> [flags]             Edit a pull request
#   forge pr comment <number> --body <text>    Post a comment on a PR
#
# issue commands:
#   forge issue list                            List open issues
#   forge issue view <number>                   Show issue details and comments
#   forge issue create --title <title> [flags]  Create an issue
#   forge issue edit <number> [flags]           Edit an issue
#   forge issue close <number-or-url> [flags]    Close an issue
#
# Config (env vars):
#   FORGE_URL          Base URL of Forgejo instance (default: https://forge.anarch.diy)
#   FORGEJO_TOKEN      API token (default: read from ~/.config/git/forgejo-token)

set -euo pipefail

FORGE_URL="${FORGE_URL:-https://forge.anarch.diy}"
FORGE_TOKEN_FILE="${FORGE_TOKEN_FILE:-$HOME/.config/git/forgejo-token}"

# --- Dependencies ---

if ! command -v jq &>/dev/null; then
  echo "forge: jq is required but not installed" >&2
  exit 1
fi
if ! command -v curl &>/dev/null; then
  echo "forge: curl is required but not installed" >&2
  exit 1
fi

# --- Auth ---

if [ -n "${FORGEJO_TOKEN:-}" ]; then
  TOKEN="$FORGEJO_TOKEN"
elif [ -r "$FORGE_TOKEN_FILE" ]; then
  TOKEN="$(cat "$FORGE_TOKEN_FILE")"
else
  echo "forge: no token found — set FORGEJO_TOKEN or ensure $FORGE_TOKEN_FILE exists" >&2
  exit 1
fi

# --- Repo inference ---

infer_repo() {
  local url
  url=$(git remote get-url origin 2>/dev/null) || {
    echo "forge: not in a git repo and --repo not specified" >&2
    exit 1
  }
  # Strip .git suffix, then extract last two path components (owner/repo)
  # Handles: ssh://git@host:port/owner/repo.git  git@host:owner/repo.git  https://host/owner/repo.git
  url="${url%.git}"
  echo "$url" | grep -oE '[^/:]+/[^/:]+$'
}

# --- Arg parsing ---

REPO=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -R|--repo)
      [[ $# -ge 2 ]] || {
        echo "forge: $1 requires a value" >&2
        exit 1
      }
      REPO="$2"
      shift 2
      ;;
    -h|--help) RESOURCE="help"; shift ;;
    *) break ;;
  esac
done

RESOURCE="${1:-help}"; [[ $# -gt 0 ]] && shift
COMMAND="${1:-}";       [[ $# -gt 0 ]] && shift

require_repo() {
  [ -n "$REPO" ] || REPO=$(infer_repo)
}

die() {
  echo "forge: $*" >&2
  exit 1
}

require_option_value() {
  local option="$1"
  local count="$2"
  [[ "$count" -ge 2 ]] || die "$option requires a value"
}

set_repo_option() {
  local option="$1"
  require_option_value "$option" "$#"
  REPO="$2"
}

parse_repo_only_args() {
  local context="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -*) die "unknown option for $context: $1" ;;
      *) die "unexpected argument for $context: $1" ;;
    esac
  done
}

POSITIONAL_ARGS=()
parse_repo_positionals() {
  local context="$1"
  shift
  POSITIONAL_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -*) die "unknown option for $context: $1" ;;
      *)
        POSITIONAL_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

reset_body_option() {
  BODY=""
  BODY_SET=false
  BODY_SOURCE=""
}

set_body_option() {
  local option="$1"
  local value="$2"
  [[ "$BODY_SET" == false ]] || {
    die "$option cannot be combined with $BODY_SOURCE"
  }

  if [[ "$option" == "-F" || "$option" == "--body-file" ]]; then
    if [[ "$value" != "-" && ! -r "$value" ]]; then
      die "cannot read body file: $value"
    fi
    local body_with_sentinel
    if [[ "$value" == "-" ]]; then
      body_with_sentinel="$(cat; printf '\x1f')"
    else
      body_with_sentinel="$(cat "$value"; printf '\x1f')"
    fi
    BODY="${body_with_sentinel%?}"
  else
    BODY="$value"
  fi

  BODY_SET=true
  BODY_SOURCE="$option"
}

# --- API helper ---

api() {
  local method="$1"; shift
  local path="$1"; shift
  curl -sf -X "$method" \
    "$FORGE_URL/api/v1$path" \
    -H "Authorization: token $TOKEN" \
    -H "Content-Type: application/json" \
    "$@"
}

# --- PR commands ---

pr_list() {
  parse_repo_only_args "pr list" "$@"
  require_repo
  local result
  result=$(api GET "/repos/$REPO/pulls?state=open&limit=50")
  local count
  count=$(echo "$result" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No open pull requests in $REPO"
    return
  fi
  echo "$result" | jq -r '.[] | "\(.number)\t\(.title)\t\(.user.login)\t\(.head.label) → \(.base.label)"' \
    | column -t -s $'\t'
}

pr_view() {
  parse_repo_positionals "pr view" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge pr view <number>"
  require_repo
  local number="${POSITIONAL_ARGS[0]}"
  local pr comments reviews

  pr=$(api GET "/repos/$REPO/pulls/$number")
  comments=$(api GET "/repos/$REPO/issues/$number/comments")
  reviews=$(api GET "/repos/$REPO/pulls/$number/reviews")

  local title state author head base
  title=$(echo "$pr" | jq -r '.title')
  state=$(echo "$pr" | jq -r '.state')
  author=$(echo "$pr" | jq -r '.user.login')
  head=$(echo "$pr" | jq -r '.head.label')
  base=$(echo "$pr" | jq -r '.base.label')

  echo "PR #$number: $title"
  echo "  State:  $state"
  echo "  Author: $author"
  echo "  Branch: $head → $base"
  echo ""

  local body
  body=$(echo "$pr" | jq -r '.body // ""')
  if [ -n "$body" ]; then
    echo "$body"
    echo ""
  fi

  local count
  count=$(echo "$comments" | jq 'length')
  if [ "$count" -gt 0 ]; then
    echo "--- $count comment(s) ---"
    echo "$comments" | jq -r '.[] | "[\(.created_at[:10])] \(.user.login):\n\(.body)\n"'
  fi

  local review_ids
  review_ids=$(echo "$reviews" | jq -r '.[] | select(.comments_count > 0) | .id')
  if [ -n "$review_ids" ]; then
    local total_inline=0
    local inline_output=""
    while IFS= read -r rid; do
      local rc
      rc=$(api GET "/repos/$REPO/pulls/$number/reviews/$rid/comments")
      local rc_count
      rc_count=$(echo "$rc" | jq 'length')
      total_inline=$((total_inline + rc_count))
      inline_output+=$(echo "$rc" | jq -r '.[] | "[\(.created_at[:10])] \(.user.login) on \(.path) line \(.line // "?"):\n\(.diff_hunk)\n> \(.body)\n"')
      inline_output+=$'\n'
    done <<< "$review_ids"
    if [ "$total_inline" -gt 0 ]; then
      echo "--- $total_inline inline comment(s) ---"
      printf '%s\n' "$inline_output"
    fi
  fi
}

pr_review_comments() {
  parse_repo_positionals "pr review-comments" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge pr review-comments <number>"
  require_repo
  local number="${POSITIONAL_ARGS[0]}"
  local reviews review_ids
  reviews=$(api GET "/repos/$REPO/pulls/$number/reviews")
  review_ids=$(echo "$reviews" | jq -r '.[] | select(.comments_count > 0) | .id')

  if [ -z "$review_ids" ]; then
    echo "No inline comments on PR #$number"
    return
  fi

  while IFS= read -r rid; do
    local rc
    rc=$(api GET "/repos/$REPO/pulls/$number/reviews/$rid/comments")
    echo "$rc" | jq -r '.[] | "id \(.id) [\(.created_at[:10])] \(.user.login) on \(.path) line \(.line // "?"):\n\(.diff_hunk)\n> \(.body)\n"'
  done <<< "$review_ids"
}

pr_edit() {
  local number="" number_set=false
  local title="" title_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr edit: $1" ;;
      *)
        [[ "$number_set" == false ]] || die "unexpected argument for pr edit: $1"
        number="$1"
        number_set=true
        shift
        ;;
    esac
  done

  [[ "$number_set" == true && -n "$number" ]] || {
    die "usage: forge pr edit <number> [--title <title>] [--body <text> | --body-file <file>]"
  }
  [[ "$title_set" == true || "$BODY_SET" == true ]] || {
    die "pr edit requires --title, --body, or --body-file"
  }
  [[ "$title_set" == false || -n "$title" ]] || die "--title cannot be empty"
  require_repo

  local payload
  payload=$(jq -n \
    --arg title "$title" \
    --arg body "$BODY" \
    --argjson title_set "$title_set" \
    --argjson body_set "$BODY_SET" \
    '{} | if $title_set then . + {title: $title} else . end
        | if $body_set  then . + {body: $body}  else . end')
  local url
  url=$(api PATCH "/repos/$REPO/pulls/$number" -d "$payload" | jq -r '.html_url')
  echo "PR updated: $url"
}

pr_comment() {
  local number="" number_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr comment: $1" ;;
      *)
        [[ "$number_set" == false ]] || die "unexpected argument for pr comment: $1"
        number="$1"
        number_set=true
        shift
        ;;
    esac
  done
  [[ "$number_set" == true && -n "$number" ]] || {
    die "usage: forge pr comment <number> [--body <text> | --body-file <file>]"
  }
  [[ "$BODY_SET" == true ]] || die "pr comment requires --body or --body-file"
  require_repo

  local url
  url=$(api POST "/repos/$REPO/issues/$number/comments" \
    -d "$(jq -n --arg body "$BODY" '{body: $body}')" | jq -r '.html_url')
  echo "Comment posted: $url"
}

pr_reply() {
  local number="" number_set=false
  local comment_id="" comment_id_set=false
  reset_body_option
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr reply: $1" ;;
      *)
        if [[ "$number_set" == false ]]; then
          number="$1"
          number_set=true
        elif [[ "$comment_id_set" == false ]]; then
          comment_id="$1"
          comment_id_set=true
        else
          die "unexpected argument for pr reply: $1"
        fi
        shift
        ;;
    esac
  done
  [[ "$number_set" == true && "$comment_id_set" == true && -n "$number" && -n "$comment_id" ]] || {
    die "usage: forge pr reply <number> <comment-id> [--body <text> | --body-file <file>]"
  }
  [[ "$BODY_SET" == true ]] || die "pr reply requires --body or --body-file"
  require_repo

  # Find the review containing the original comment.
  # Replies must go to POST /reviews/{id}/comments — posting to a new review
  # doesn't thread correctly regardless of path/position/in_reply_to fields.
  local reviews review_ids orig_review_id="" orig_path="" orig_position=0
  reviews=$(api GET "/repos/$REPO/pulls/$number/reviews")
  review_ids=$(echo "$reviews" | jq -r '.[] | select(.comments_count > 0) | .id')

  while IFS= read -r rid; do
    local rc match
    rc=$(api GET "/repos/$REPO/pulls/$number/reviews/$rid/comments")
    match=$(echo "$rc" | jq -r --argjson cid "$comment_id" 'first(.[] | select(.id == $cid)) // empty')
    if [ -n "$match" ]; then
      orig_review_id="$rid"
      orig_path=$(echo "$match"     | jq -r '.path')
      orig_position=$(echo "$match" | jq -r '.position // 0')
      break
    fi
  done <<< "$review_ids"

  # TODO: starting a new inline thread (no existing comment to reply to) requires
  # POST /reviews with a comment containing path + new_position. Add a
  # `forge pr inline <number> <path> <line> <body>` command when agentic review is needed.

  if [ -z "$orig_review_id" ]; then
    echo "forge: comment $comment_id not found on PR #$number" >&2
    exit 1
  fi

  local url
  url=$(api POST "/repos/$REPO/pulls/$number/reviews/$orig_review_id/comments" \
    -d "$(jq -n \
      --arg path "$orig_path" \
      --argjson new_position "$orig_position" \
      --arg body "$BODY" \
      '{path: $path, new_position: $new_position, body: $body}')" \
    | jq -r '.html_url')
  echo "Reply posted: $url"
}

pr_create() {
  local title="" head="" base=""
  local title_set=false head_set=false base_set=false
  reset_body_option

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -R|--repo)
        set_repo_option "$@"
        shift 2
        ;;
      -t|--title)
        require_option_value "$1" "$#"
        [[ "$title_set" == false ]] || die "$1 specified more than once"
        title="$2"
        title_set=true
        shift 2
        ;;
      -H|--head)
        require_option_value "$1" "$#"
        [[ "$head_set" == false ]] || die "$1 specified more than once"
        head="$2"
        head_set=true
        shift 2
        ;;
      -B|--base)
        require_option_value "$1" "$#"
        [[ "$base_set" == false ]] || die "$1 specified more than once"
        base="$2"
        base_set=true
        shift 2
        ;;
      -b|--body|-F|--body-file)
        require_option_value "$1" "$#"
        set_body_option "$1" "$2"
        shift 2
        ;;
      -*) die "unknown option for pr create: $1" ;;
      *) die "unexpected argument for pr create: $1" ;;
    esac
  done

  [[ "$title_set" == true ]] || die "pr create requires --title"
  [[ -n "$title" ]] || die "--title cannot be empty"
  [[ "$head_set" == false || -n "$head" ]] || die "--head cannot be empty"
  [[ "$base_set" == false || -n "$base" ]] || die "--base cannot be empty"
  require_repo

  if [[ "$head_set" == false ]]; then
    head=$(git branch --show-current 2>/dev/null || true)
    [[ -n "$head" ]] || {
      die "cannot infer PR head branch; use --head"
    }
  fi

  if [[ "$base_set" == false ]]; then
    base=$(api GET "/repos/$REPO" | jq -r '.default_branch // empty')
    [[ -n "$base" ]] || {
      die "could not determine repository default branch; use --base"
    }
  fi

  local url
  url=$(api POST "/repos/$REPO/pulls" \
    -d "$(jq -n \
      --arg title "$title" \
      --arg head "$head" \
      --arg base "$base" \
      --arg body "$BODY" \
      '{title: $title, head: $head, base: $base, body: $body}')" \
    | jq -r '.html_url')
  echo "PR created: $url"
}

pr_find_by_head() {
  parse_repo_positionals "pr find-by-head" "$@"
  [[ "${#POSITIONAL_ARGS[@]}" -eq 1 ]] || die "usage: forge pr find-by-head <branch>"
  require_repo
  local head_branch="${POSITIONAL_ARGS[0]}"
  # Prints the PR number if an open PR exists for this head branch; prints nothing if not found.
  api GET "/repos/$REPO/pulls?state=open&limit=50&head=${head_branch}" \
    | jq -r 'first(.[] | .number) // empty'
}

