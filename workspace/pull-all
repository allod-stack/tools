#!/usr/bin/env bash
# pull-all - pull every repo under ~/work/
#
# For each repo:
#   - Skips if working tree is dirty
#   - Pulls the current branch and reports what happened
#   - With --switch, checks out the default branch first (if safe)
#
# Repos are processed in parallel, capped by PULL_ALL_JOBS.
#
# Options:
#   --switch  Switch repos on non-default branches to the default
#                       branch before pulling (skips if unpushed commits exist)
#   PULL_ALL_JOBS=N     Limit concurrent pulls (default: 4)
#   -h, --help          Show this help message

set -euo pipefail

SWITCH_DEFAULT=false
PULL_ALL_JOBS="${PULL_ALL_JOBS:-4}"

for arg in "$@"; do
  case "$arg" in
    --switch) SWITCH_DEFAULT=true ;;
    -h|--help)
      sed -n '2,${/^#/!q; s/^# \{0,1\}//; p;}' "$0"
      exit 0
      ;;
    *)
      printf 'pull-all: unknown option: %s\n' "$arg" >&2
      exit 1
      ;;
  esac
done

if ! [[ "$PULL_ALL_JOBS" =~ ^[1-9][0-9]*$ ]]; then
  printf 'pull-all: PULL_ALL_JOBS must be a positive integer, got: %s\n' "$PULL_ALL_JOBS" >&2
  exit 1
fi

if ! declare -F workspace_collect_repos >/dev/null; then
  # shellcheck source=/dev/null
  source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/../lib/workspace.sh"
fi

mapfile -t REPOS < <(workspace_collect_repos "$WORK_DIR")

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

process_repo() {
  local repo="$1" dir="$2" outfile="$3"

  local default_branch current_branch
  default_branch=$(workspace_repo_default_branch "$dir")
  current_branch=$(git -C "$dir" branch --show-current 2>/dev/null || true)

  # Skip dirty repos
  if ! git -C "$dir" diff --quiet 2>/dev/null || \
     ! git -C "$dir" diff --cached --quiet 2>/dev/null; then
    printf '  %-24s  skipped    [dirty working tree]\n' "$repo" > "$outfile"
    return
  fi

  # With --switch, try to check out the default branch first
  if [[ "$current_branch" != "$default_branch" && "$SWITCH_DEFAULT" == true ]]; then
    if ! git -C "$dir" rev-parse --abbrev-ref "@{u}" >/dev/null 2>&1; then
      printf '  %-24s  skipped    [on %s — no remote tracking branch]\n' "$repo" "$current_branch" > "$outfile"
      return
    fi
    local unpushed
    unpushed=$(git -C "$dir" rev-list "HEAD...@{u}" --count 2>/dev/null || echo 0)
    if [[ "$unpushed" -gt 0 ]]; then
      if [[ "$unpushed" -eq 1 ]]; then
        printf '  %-24s  skipped    [on %s — 1 unpushed commit]\n' "$repo" "$current_branch" > "$outfile"
      else
        printf '  %-24s  skipped    [on %s — %d unpushed commits]\n' "$repo" "$current_branch" "$unpushed" > "$outfile"
      fi
      return
    fi
    if ! git -C "$dir" checkout "$default_branch" > /dev/null 2>&1; then
      printf '  %-24s  error      [checkout %s failed]\n' "$repo" "$default_branch" > "$outfile"
      return
    fi
    current_branch="$default_branch"
  fi

  # Pull
  local pull_out
  pull_out=$(git -C "$dir" pull 2>&1) || {
    printf '  %-24s  error      [pull failed: %s]\n' "$repo" "$(printf '%s' "$pull_out" | head -1)" > "$outfile"
    return
  }
  if printf '%s' "$pull_out" | grep -q "Already up to date"; then
    printf '  %-24s  up to date [%s]\n' "$repo" "$current_branch" > "$outfile"
  else
    printf '  %-24s  pulled     [%s]\n' "$repo" "$current_branch" > "$outfile"
  fi
}

running=0
for i in "${!REPOS[@]}"; do
  repo="${REPOS[$i]}"
  dir="${WORK_DIR}/${repo}"
  [[ -d "$dir" ]] || continue

  process_repo "$repo" "$dir" "$tmpdir/$i" &
  running=$((running + 1))
  if (( running >= PULL_ALL_JOBS )); then
    wait -n 2>/dev/null || true
    running=$((running - 1))
  fi
done

wait

# Print results in original repo order
for i in "${!REPOS[@]}"; do
  if [[ -f "$tmpdir/$i" ]]; then
    cat "$tmpdir/$i"
  elif [[ -d "${WORK_DIR}/${REPOS[$i]}" ]]; then
    printf '  %-24s  error      [unexpected failure]\n' "${REPOS[$i]}"
  fi
done
