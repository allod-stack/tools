#!/usr/bin/env bash
set -euo pipefail

WORK_DIR="${HOME}/work"

usage() {
    cat <<'EOF'
Usage: work-diff [--all | <repo-name>]

  (no args)       show all git repos in ~/work
  --all           same as above
  <repo-name>     show only ~/work/<repo-name>
  -h, --help      this message
EOF
    exit 0
}

sep() { printf '%.0s═' $(seq 1 60); echo; }

is_repo_root() {
    local dir="$1" top
    [[ -e "$dir/.git" ]] || return 1
    top=$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null) || return 1
    [[ "$top" == "$dir" ]]
}

show_repo() {
    local dir="$1"
    is_repo_root "$dir" || return 0

    local name branch status staged unstaged
    name="${dir#"$WORK_DIR"/}"
    name="${name%/}"
    branch=$(git -C "$dir" branch --show-current 2>/dev/null)
    status=$(git -C "$dir" status --porcelain 2>/dev/null)

    echo
    sep
    printf '  %s  [%s]\n' "$name" "$branch"
    sep

    if [[ -z "$status" ]]; then
        echo "  (clean)"
        return 0
    fi

    echo "$status"

    staged=$(git -C "$dir" diff --cached 2>/dev/null)
    unstaged=$(git -C "$dir" diff 2>/dev/null)

    [[ -n "$staged" ]]   && printf '\n--- staged ---\n%s\n' "$staged"
    [[ -n "$unstaged" ]] && printf '\n--- unstaged ---\n%s\n' "$unstaged"
}

walk() {
    local dir="${1%/}"
    if is_repo_root "$dir"; then
        show_repo "$dir"
        return
    fi
    for sub in "$dir"/*/; do
        [[ -d "$sub" ]] || continue
        walk "$sub"
    done
}

show_all() {
    walk "$WORK_DIR"
}

case "${1:-}" in
    -h|--help) usage ;;
    --all|"")  show_all ;;
    -*)        echo "Unknown option: $1" >&2; exit 1 ;;
    *)
        [[ -d "$WORK_DIR/$1" ]] || { echo "Error: '$1' not found in $WORK_DIR" >&2; exit 1; }
        show_repo "$WORK_DIR/$1"
        ;;
esac
