#!/usr/bin/env bash
# pull-all - checkout default branch and pull every repo under ~/work/
#
# For each repo:
#   - Skips if working tree is dirty
#   - Skips if on a non-default branch with unpushed commits
#   - Checks out default branch if on a different branch (clean, nothing unpushed)
#   - Pulls and reports what happened

set -euo pipefail

WORK_DIR="${HOME}/work"

if ! declare -F workspace_collect_repos >/dev/null; then
  source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/workspace.sh"
fi

mapfile -t REPOS < <(workspace_collect_repos "$WORK_DIR")

for repo in "${REPOS[@]}"; do
  dir="${WORK_DIR}/${repo}"
  [[ -d "$dir" ]] || continue

  default_branch=$(workspace_repo_default_branch "$dir")
  current_branch=$(git -C "$dir" branch --show-current 2>/dev/null || true)

  # Skip dirty repos
  if ! git -C "$dir" diff --quiet 2>/dev/null || \
     ! git -C "$dir" diff --cached --quiet 2>/dev/null; then
    printf '  %-24s  skipped    [dirty working tree]\n' "$repo"
    continue
  fi

  # If on a non-default branch, only switch if nothing is unpushed.
  # No upstream tracking branch → treat as unpushed (safe default).
  if [[ "$current_branch" != "$default_branch" ]]; then
    if ! git -C "$dir" rev-parse --abbrev-ref "@{u}" >/dev/null 2>&1; then
      printf '  %-24s  skipped    [on %s — no remote tracking branch]\n' "$repo" "$current_branch"
      continue
    fi
    unpushed=$(git -C "$dir" rev-list "HEAD...@{u}" --count 2>/dev/null || echo 0)
    if [[ "$unpushed" -gt 0 ]]; then
      if [[ "$unpushed" -eq 1 ]]; then
        printf '  %-24s  skipped    [on %s — 1 unpushed commit]\n' "$repo" "$current_branch"
      else
        printf '  %-24s  skipped    [on %s — %d unpushed commits]\n' "$repo" "$current_branch" "$unpushed"
      fi
      continue
    fi
    if ! git -C "$dir" checkout "$default_branch" > /dev/null 2>&1; then
      printf '  %-24s  error      [checkout %s failed]\n' "$repo" "$default_branch"
      continue
    fi
  fi

  # Pull
  pull_out=$(git -C "$dir" pull 2>&1) || {
    printf '  %-24s  error      [pull failed: %s]\n' "$repo" "$(printf '%s' "$pull_out" | head -1)"
    continue
  }
  if printf '%s' "$pull_out" | grep -q "Already up to date"; then
    printf '  %-24s  up to date [%s]\n' "$repo" "$default_branch"
  else
    printf '  %-24s  pulled     [%s]\n' "$repo" "$default_branch"
  fi
done
