#!/usr/bin/env bash
set -euo pipefail

# --- Color support ---
if [[ -t 1 ]]; then
  YELLOW=$'\033[33m'
  RESET=$'\033[0m'
else
  YELLOW="" RESET=""
fi

if ! declare -F workspace_collect_repos >/dev/null; then
  # shellcheck source=/dev/null
  source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/../lib/workspace.sh"
fi

mapfile -t REPOS < <(workspace_collect_repos "$WORK_DIR")

usage() {
  cat <<'EOF'
Usage: flake-status [input-name] [--upstream]

  (no args)          show all inputs for all repos
  <input-name>       show only that input across all repos
  --upstream         compare pins against upstream remote HEAD (network)

Examples:
  flake-status
  flake-status vm
  flake-status nixpkgs --upstream
EOF
}

# --- Arg parsing ---

INPUT_NAME=""
CHECK_UPSTREAM=false

for arg in "$@"; do
  case "$arg" in
    --upstream) CHECK_UPSTREAM=true ;;
    -h|--help) usage; exit 0 ;;
    -*) echo "flake-status: unknown option: $arg" >&2; usage >&2; exit 1 ;;
    *)
      if [[ -n "$INPUT_NAME" ]]; then
        echo "flake-status: unexpected argument: $arg" >&2; exit 1
      fi
      INPUT_NAME="$arg"
      ;;
  esac
done

# --- Parallel infrastructure ---

FLAKE_STATUS_JOBS="${FLAKE_STATUS_JOBS:-4}"
_PTMP=""

_parallel_init() {
  _PTMP=$(mktemp -d)
  mkdir -p "$_PTMP/repo" "$_PTMP/urls" "$_PTMP/upstream"
}

trap '[[ -n "${_PTMP:-}" ]] && rm -rf "$_PTMP"' EXIT

# Run "$@ $i" for i in 0..(count-1), bounded by FLAKE_STATUS_JOBS.
_parallel_for() {
  local count="$1"; shift
  local running=0 i
  for (( i=0; i<count; i++ )); do
    "$@" "$i" &
    running=$((running + 1))
    if (( running >= FLAKE_STATUS_JOBS )); then
      wait -n 2>/dev/null || true
      running=$((running - 1))
    fi
  done
  wait
}

# --- jq helpers ---

# Get rev (7-char) and date (YYYY-MM-DD) for a named direct-pin input.
# Outputs "rev\tdate" or nothing if absent/uses follows.
get_input_pin() {
  local lockfile="$1" name="$2"
  jq -r --arg name "$name" '
    . as $root
    | .nodes.root.inputs[$name]
    | if . == null or type != "string" then empty
      else . as $k
      | $root.nodes[$k].locked
      | select(.rev != null)
      | [.rev[0:7], (.lastModified | todate | .[0:10])]
      | @tsv
      end
  ' "$lockfile"
}

# Get all directly-pinned root inputs (excludes follows).
# Outputs "name\trev\tdate" per line.
get_all_inputs() {
  local lockfile="$1"
  jq -r '
    . as $root
    | .nodes.root.inputs
    | to_entries[]
    | select(.value | type == "string")
    | .key as $name
    | .value as $k
    | $root.nodes[$k].locked
    | select(.rev != null)
    | [$name, .rev[0:7], (.lastModified | todate | .[0:10])]
    | @tsv
  ' "$lockfile"
}

# Get upstream URL for a named input (github or git type only).
get_upstream_url() {
  local lockfile="$1" name="$2"
  jq -r --arg name "$name" '
    . as $root
    | .nodes.root.inputs[$name]
    | if . == null or type != "string" then empty
      else . as $k
      | $root.nodes[$k].original
      | if .type == "github" then "https://github.com/\(.owner)/\(.repo)"
        elif .type == "git" then .url
        else empty
        end
      end
  ' "$lockfile"
}

# --- Git helpers ---

# Output health warning strings for a repo (space-separated, may be empty).
repo_health_warnings() {
  local dir="$1"
  local -a warnings=()

  local branch
  branch=$(git -C "$dir" branch --show-current 2>/dev/null || true)
  local default_branch
  default_branch=$(workspace_repo_default_branch "$dir")
  if [[ -n "$branch" && "$branch" != "$default_branch" ]]; then
    warnings+=("[on branch $branch, not $default_branch]")
  fi

  if ! git -C "$dir" diff --cached --quiet 2>/dev/null; then
    warnings+=("[dirty: staged changes]")
  elif ! git -C "$dir" diff --quiet 2>/dev/null; then
    warnings+=("[dirty: unstaged changes]")
  fi

  local unpushed=0
  unpushed=$(git -C "$dir" rev-list "HEAD...@{u}" --count 2>/dev/null || echo 0)
  if [[ "$unpushed" -gt 0 ]]; then
    if [[ "$unpushed" -eq 1 ]]; then
      warnings+=("[1 unpushed commit]")
    else
      warnings+=("[$unpushed unpushed commits]")
    fi
  fi

  if [[ ${#warnings[@]} -gt 0 ]]; then
    printf '%s' "${warnings[*]}"
  fi
}

# --- Upstream resolution ---

# Resolve a single URL from $_PTMP/unique_urls (line $1+1) into $_PTMP/upstream/$1.
_resolve_one_url() {
  local idx="$1"
  local url
  url=$(sed -n "$((idx + 1))p" "$_PTMP/unique_urls")
  local rev
  rev=$(git ls-remote "$url" HEAD 2>/dev/null | cut -f1 | head -1 || true)
  printf '%s' "${rev:-}" > "$_PTMP/upstream/$idx"
}

# Collect unique URLs from $_PTMP/urls/*, resolve each in parallel.
_resolve_all_upstreams() {
  cat "$_PTMP"/urls/* 2>/dev/null | cut -f2 | sort -u \
    > "$_PTMP/unique_urls" 2>/dev/null || true
  [[ -s "$_PTMP/unique_urls" ]] || return 0
  local count
  count=$(wc -l < "$_PTMP/unique_urls")
  (( count > 0 )) && _parallel_for "$count" _resolve_one_url
}

# Look up resolved rev for a URL. Prints the rev or nothing.
_lookup_upstream_rev() {
  local url="$1"
  [[ -f "$_PTMP/unique_urls" ]] || return 0
  local line_num
  line_num=$(grep -nxF "$url" "$_PTMP/unique_urls" | head -1 | cut -d: -f1 || true)
  [[ -n "$line_num" ]] || return 0
  local file="$_PTMP/upstream/$((line_num - 1))"
  [[ -f "$file" ]] && cat "$file" || true
}

# --- Named input mode ---

# Collect data for one repo. Writes a single TSV line to $_PTMP/repo/$1:
#   status \t rev \t date \t health
# Also writes "$INPUT_NAME \t url" to $_PTMP/urls/$1 when upstream is requested.
_collect_named() {
  local i="$1"
  local repo="${REPOS[$i]}"
  local dir="${WORK_DIR}/${repo}"
  local out="$_PTMP/repo/$i"

  if [[ ! -d "$dir" ]] || [[ ! -f "${dir}/flake.lock" ]]; then
    printf 'skip\t\t\t\n' > "$out"
    return
  fi

  local health=""
  health=$(repo_health_warnings "$dir")

  local pin=""
  pin=$(get_input_pin "${dir}/flake.lock" "$INPUT_NAME")

  if [[ -z "$pin" ]]; then
    printf 'not-input\t\t\t%s\n' "$health" > "$out"
  else
    local rev date
    rev=$(printf '%s' "$pin" | cut -f1)
    date=$(printf '%s' "$pin" | cut -f2)
    printf 'ok\t%s\t%s\t%s\n' "$rev" "$date" "$health" > "$out"

    if [[ "$CHECK_UPSTREAM" == true ]]; then
      local url=""
      url=$(get_upstream_url "${dir}/flake.lock" "$INPUT_NAME")
      [[ -n "$url" ]] && printf '%s\t%s\n' "$INPUT_NAME" "$url" > "$_PTMP/urls/$i"
    fi
  fi
}

show_named_input() {
  local input_name="$1"

  _parallel_init
  _parallel_for "${#REPOS[@]}" _collect_named

  # Read collected data in workspace order
  local -a names=() revs=() dates=() statuses=() healths=()
  local i
  for (( i=0; i<${#REPOS[@]}; i++ )); do
    local file="$_PTMP/repo/$i"
    [[ -f "$file" ]] || continue

    local status rev date health
    IFS=$'\t' read -r status rev date health < "$file"

    [[ "$status" == "skip" ]] && continue

    names+=("${REPOS[$i]}")
    statuses+=("$status")
    revs+=("$rev")
    dates+=("$date")
    healths+=("$health")
  done

  if [[ ${#names[@]} -eq 0 ]]; then
    echo "No repos found in ${WORK_DIR}"
    return
  fi

  # Find majority rev (most common among "ok" entries)
  local -A rev_counts=()
  local majority_rev="" max_count=0 ok_count=0

  for i in "${!statuses[@]}"; do
    if [[ "${statuses[$i]}" == "ok" ]]; then
      ok_count=$(( ok_count + 1 ))
      local r="${revs[$i]}"
      rev_counts["$r"]=$(( ${rev_counts["$r"]:-0} + 1 ))
      if [[ "${rev_counts[$r]}" -gt "$max_count" ]]; then
        max_count="${rev_counts[$r]}"
        majority_rev="$r"
      fi
    fi
  done

  local diff_count=0
  for i in "${!statuses[@]}"; do
    if [[ "${statuses[$i]}" == "ok" && "${revs[$i]}" != "$majority_rev" ]]; then
      diff_count=$(( diff_count + 1 ))
    fi
  done

  # Header
  if [[ "$ok_count" -eq 0 ]]; then
    echo "${input_name} — no repos have this input"
  elif [[ "$diff_count" -gt 0 ]]; then
    if [[ "$diff_count" -eq 1 ]]; then
      echo "${input_name} — INCONSISTENT (1 repo differs)"
    else
      echo "${input_name} — INCONSISTENT (${diff_count} repos differ)"
    fi
  else
    local majority_date=""
    for i in "${!statuses[@]}"; do
      if [[ "${statuses[$i]}" == "ok" ]]; then
        majority_date="${dates[$i]}"
        break
      fi
    done
    echo "${input_name} — all repos consistent at ${majority_rev} (${majority_date})"
  fi

  echo ""

  # Per-repo rows
  for i in "${!names[@]}"; do
    local name="${names[$i]}" status="${statuses[$i]}" health="${healths[$i]}"
    local health_str=""
    [[ -n "$health" ]] && health_str="  ${health}"

    case "$status" in
      not-input)
        printf '  %-20s  %s\n' "$name" "(not an input)"
        ;;
      ok)
        local rev="${revs[$i]}" date="${dates[$i]}" stale=""
        [[ -n "$majority_rev" && "$rev" != "$majority_rev" ]] && stale="  ← stale"
        printf '  %-20s  %-7s  %-10s%s%s\n' "$name" "$rev" "$date" "$health_str" "$stale"
        ;;
    esac
  done

  # Upstream check
  if [[ "$CHECK_UPSTREAM" == true && "$ok_count" -gt 0 ]]; then
    _resolve_all_upstreams

    local upstream_url=""
    for (( i=0; i<${#REPOS[@]}; i++ )); do
      local uf="$_PTMP/urls/$i"
      [[ -f "$uf" ]] || continue
      upstream_url=$(head -1 "$uf" | cut -f2)
      [[ -n "$upstream_url" ]] && break
    done

    echo ""
    if [[ -n "$upstream_url" ]]; then
      local upstream_rev=""
      upstream_rev=$(_lookup_upstream_rev "$upstream_url")
      if [[ -n "$upstream_rev" ]]; then
        local short_upstream="${upstream_rev:0:7}"
        if [[ "$majority_rev" == "$short_upstream" ]]; then
          echo "upstream: up to date at ${short_upstream}"
        else
          echo "upstream: ${short_upstream} (local pins are behind)"
        fi
      else
        echo "upstream: (could not fetch)"
      fi
    else
      echo "upstream: (no fetchable URL for this input)"
    fi
  fi
}

# --- All-inputs mode ---

# Collect data for one repo. Writes to $_PTMP/repo/$1:
#   Line 1: included \t health
#   Lines 2+: name \t rev \t date (one per input)
# Also writes "name \t url" lines to $_PTMP/urls/$1 when upstream is requested.
_collect_all() {
  local i="$1"
  local repo="${REPOS[$i]}"
  local dir="${WORK_DIR}/${repo}"
  local out="$_PTMP/repo/$i"

  if [[ ! -d "$dir" ]] || [[ ! -f "${dir}/flake.lock" ]]; then
    printf '0\t\n' > "$out"
    return
  fi

  local inputs=""
  inputs=$(get_all_inputs "${dir}/flake.lock")
  if [[ -z "$inputs" ]]; then
    printf '0\t\n' > "$out"
    return
  fi

  local health=""
  health=$(repo_health_warnings "$dir")

  {
    printf '1\t%s\n' "$health"
    printf '%s\n' "$inputs"
  } > "$out"

  if [[ "$CHECK_UPSTREAM" == true ]]; then
    local urls_out="$_PTMP/urls/$i"
    while IFS=$'\t' read -r name _rev _date; do
      local url=""
      url=$(get_upstream_url "${dir}/flake.lock" "$name")
      [[ -n "$url" ]] && printf '%s\t%s\n' "$name" "$url"
    done <<< "$inputs" > "$urls_out"
    [[ -s "$urls_out" ]] || rm -f "$urls_out"
  fi
}

show_all_inputs() {
  _parallel_init
  _parallel_for "${#REPOS[@]}" _collect_all

  if [[ "$CHECK_UPSTREAM" == true ]]; then
    _resolve_all_upstreams
  fi

  local first=true i
  declare -A _outdated_local=()
  declare -A _outdated_external=()

  for (( i=0; i<${#REPOS[@]}; i++ )); do
    local file="$_PTMP/repo/$i"
    [[ -f "$file" ]] || continue

    local included health
    IFS=$'\t' read -r included health < "$file"
    [[ "$included" == "1" ]] || continue

    [[ "$first" == true ]] && first=false || echo ""

    local health_str=""
    [[ -n "$health" ]] && health_str="  ${health}"

    echo "==> ${REPOS[$i]}${health_str}"

    while IFS=$'\t' read -r name rev date; do
      local suffix=""
      if [[ "$CHECK_UPSTREAM" == true ]]; then
        local url=""
        local urls_file="$_PTMP/urls/$i"
        if [[ -f "$urls_file" ]]; then
          url=$(grep -m1 "^${name}"$'\t' "$urls_file" 2>/dev/null | cut -f2 || true)
        fi
        if [[ -n "$url" ]]; then
          local urev=""
          urev=$(_lookup_upstream_rev "$url")
          if [[ -n "$urev" ]]; then
            local short_urev="${urev:0:7}"
            if [[ "$rev" != "$short_urev" ]]; then
              suffix="  ${YELLOW}→ ${short_urev}${RESET}"
              if [[ "$url" == *"forge.anarch.diy"* ]]; then
                _outdated_local["$name"]=1
              else
                _outdated_external["$name"]=1
              fi
            fi
          fi
        fi
      fi
      printf '  %-20s  %-7s  %-10s%s\n' "$name" "$rev" "$date" "$suffix"
    done < <(tail -n +2 "$file")
  done

  if [[ ${#_outdated_local[@]} -gt 0 || ${#_outdated_external[@]} -gt 0 ]]; then
    echo ""
    if [[ ${#_outdated_local[@]} -gt 0 ]]; then
      echo "Outdated (local):"
      echo "  flake-update-cascade ${!_outdated_local[*]}"
    fi
    if [[ ${#_outdated_external[@]} -gt 0 ]]; then
      echo "Outdated (external):"
      echo "  flake-update-cascade ${!_outdated_external[*]}"
    fi
  fi
}

# --- Dispatch ---

if [[ -n "$INPUT_NAME" ]]; then
  show_named_input "$INPUT_NAME"
else
  show_all_inputs
fi
