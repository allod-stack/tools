#!/bin/sh
# render - deterministic (pm.json + forge issue data) -> self-contained pm.html.
#
# Emits a single self-contained page to stdout: semantic HTML + inline <style>,
# NO <script>, NO external URLs. The forge renders committed .html in a sandboxed
# iframe (RENDER_CONTENT_MODE=iframe) that executes no JS and loads no external
# resources, so the output must stand alone.
#
# Usage:
#   render [--issue-snapshot <file>] <pm.json>
#
# --issue-snapshot <file>  Read issue data from a fixed JSON snapshot instead of
#                          the live forge. The snapshot is a JSON object keyed by
#                          "owner/repo#num" with { "title": ..., "state": ... }:
#                            { "allod/tools#103": {"title":"...","state":"open"} }
#                          Same pm.json + same snapshot => byte-identical output.
#
# Live mode fetches title+state per referenced issue from the forge using the
# token the `forge` CLI reads (~/.config/git/forgejo-token, or $FORGEJO_TOKEN /
# $FORGEJO_TOKEN_FILE). All forge-sourced text is HTML-escaped. Issue links are
# forge-root-relative paths (/owner/repo/issues/num), never absolute URLs.
# Exits non-zero if any referenced issue is missing from the fetch/snapshot -
# dangling refs fail loudly, they do not become silent placeholders.
set -eu

FORGE="${FORGEJO_HOST:-https://forge.anarch.diy}"
TOKEN_FILE="${FORGEJO_TOKEN_FILE:-$HOME/.config/git/forgejo-token}"

usage() { echo "usage: render [--issue-snapshot <file>] <pm.json>" >&2; exit 2; }

snapshot=""
pm=""
while [ $# -gt 0 ]; do
  case "$1" in
    --issue-snapshot) [ $# -ge 2 ] || usage; snapshot="$2"; shift 2 ;;
    --issue-snapshot=*) snapshot="${1#*=}"; shift ;;
    -h|--help) usage ;;
    --) shift; break ;;
    -*) echo "render: unknown option: $1" >&2; usage ;;
    *) [ -z "$pm" ] || { echo "render: unexpected extra argument: $1" >&2; usage; }; pm="$1"; shift ;;
  esac
done
[ -n "$pm" ] || usage
[ -f "$pm" ] || { echo "render: no such pm.json: $pm" >&2; exit 2; }
jq -e . "$pm" >/dev/null 2>&1 || { echo "render: $pm is not valid JSON" >&2; exit 2; }

# Authoritative list of referenced issue refs, gathered from the known overlay
# locations (matches the schema) - unique, deterministic order.
refs=$(jq -r '
  [ (.plans[]?.phases[]?.issues[]?),
    (.priority[]?.issue),
    (.gates[]?.blocked),
    (.gates[]?.by[]?),
    (.decisions_pending[]?.issue) ]
  | map(select(. != null)) | unique[]' "$pm")

# Build the issue index: { "owner/repo#num": {title,state} }.
if [ -n "$snapshot" ]; then
  [ -f "$snapshot" ] || { echo "render: no such snapshot: $snapshot" >&2; exit 2; }
  jq -e 'type=="object"' "$snapshot" >/dev/null 2>&1 \
    || { echo "render: snapshot must be a JSON object keyed by owner/repo#num" >&2; exit 2; }
  idx=$(cat "$snapshot")
else
  token=$(printf '%s' "${FORGEJO_TOKEN:-}")
  [ -n "$token" ] || token=$(cat "$TOKEN_FILE" 2>/dev/null || true)
  [ -n "$token" ] || { echo "render: no forge token (\$FORGEJO_TOKEN or $TOKEN_FILE)" >&2; exit 2; }
  idx='{}'
  for ref in $refs; do
    repo=${ref%#*}; num=${ref#*#}
    data=$(curl -sf -H "Authorization: token $token" \
      "$FORGE/api/v1/repos/$repo/issues/$num" 2>/dev/null || true)
    [ -n "$data" ] || continue
    entry=$(printf '%s' "$data" \
      | jq -c --arg ref "$ref" '{($ref): {title: .title, state: .state}}' 2>/dev/null || true)
    [ -n "$entry" ] || continue
    idx=$(printf '%s\n%s\n' "$idx" "$entry" | jq -cs '.[0] * .[1]')
  done
fi

# Fail loudly on any ref missing from the index (dangling / unresolved).
missing=""
for ref in $refs; do
  if ! printf '%s' "$idx" | jq -e --arg r "$ref" 'has($r)' >/dev/null 2>&1; then
    missing="$missing $ref"
  fi
done
if [ -n "$missing" ]; then
  echo "render: unresolved issue refs (dangling, or missing from snapshot):$missing" >&2
  exit 3
fi

# Build the page body in jq so every forge-sourced string is @html-escaped there.
body=$(jq -r --argjson idx "$idx" '
  def e: @html;
  def href($ref): ($ref | split("#")) as $p | "/" + $p[0] + "/issues/" + $p[1];
  def reflink($ref):
    "<a class=\"ref\" href=\"" + (href($ref)|e) + "\">" + ($ref|e) + "</a>";
  def state($ref):
    ($idx[$ref].state // "unknown") as $s
    | "<span class=\"state s-" + ($s|e) + "\">" + ($s|e) + "</span>";
  def title($ref):
    "<span class=\"title\">" + (($idx[$ref].title // "")|e) + "</span>";
  def issuerow($ref):
    "<li class=\"issue\">" + reflink($ref) + " " + state($ref) + " " + title($ref) + "</li>";

  [ "<main>",
    "<header class=\"board\">",
    "  <h1>Project Board</h1>",
    "  <p class=\"meta\">Updated " + ((.updated // "")|e)
      + " · Managed repos: " + (((.repos // []) | map(e)) | join(", ")) + "</p>",
    "  <p class=\"prov\">Overlay board generated by the PM render tool. Forgejo is authoritative for issue titles and state.</p>",
    "</header>"
  ]
  + ( if ((.priority // []) | length) > 0 then
        [ "<section class=\"priority\">", "<h2>Priority</h2>", "<ol class=\"issues\">" ]
        + ( .priority | to_entries | map(
              "<li class=\"issue\"><span class=\"tier t-" + (.value.tier|e) + "\">"
              + (.value.tier|e) + "</span> " + reflink(.value.issue) + " "
              + state(.value.issue) + " " + title(.value.issue)
              + ( if .value.note then " <span class=\"pnote\">- " + (.value.note|e) + "</span>" else "" end )
              + "</li>" ) )
        + [ "</ol>", "</section>" ]
      else [] end )
  + ( if ((.plans // []) | length) > 0 then
        [ "<section class=\"plans\">", "<h2>Plans</h2>" ]
        + ( [ .plans[] |
              [ "<article class=\"plan\">",
                "<h3>" + ((.title // .id)|e)
                  + ( if .status then " <span class=\"status st-" + (.status|e) + "\">" + (.status|e) + "</span>" else "" end )
                  + "</h3>" ]
              + ( if .goal then [ "<p class=\"goal\">" + (.goal|e) + "</p>" ] else [] end )
              + ( [ (.phases // [])[] |
                    [ "<div class=\"phase\">",
                      "<h4>" + (.id|e)
                        + ( if .gate then " <span class=\"gate\">gate: " + (.gate|e) + "</span>" else "" end )
                        + "</h4>",
                      "<ul class=\"issues\">" ]
                    + ( (.issues // []) | map(issuerow(.)) )
                    + [ "</ul>", "</div>" ] ] | add // [] )
              + [ "</article>" ] ] | add // [] )
        + [ "</section>" ]
      else [] end )
  + ( if ((.gates // []) | length) > 0 then
        [ "<section class=\"gates\">", "<h2>Gates</h2>", "<ul class=\"gatelist\">" ]
        + ( .gates | map(
              "<li class=\"gateitem\">" + reflink(.blocked) + " " + state(.blocked)
              + " <span class=\"blockedby\">blocked by</span> "
              + ( (.by // []) | map(reflink(.)) | join(", ") )
              + ( if .reason then " <span class=\"reason\">- " + (.reason|e) + "</span>" else "" end )
              + "</li>" ) )
        + [ "</ul>", "</section>" ]
      else [] end )
  + ( if ((.decisions_pending // []) | length) > 0 then
        [ "<section class=\"decisions\">", "<h2>Pending decisions</h2>", "<ul class=\"declist\">" ]
        + ( .decisions_pending | map(
              "<li class=\"decitem\"><strong>" + (.id|e) + "</strong> " + (.q|e)
              + ( if .issue then " " + reflink(.issue) + " " + state(.issue) else "" end )
              + "</li>" ) )
        + [ "</ul>", "</section>" ]
      else [] end )
  + [ "</main>" ]
  | join("\n")
' "$pm")

# Splice the deterministic body into a static, self-contained skeleton. The
# static parts use a quoted heredoc (no shell expansion); the body is emitted
# with printf %s so no $/backtick inside an escaped title is ever re-interpreted.
cat <<'HEAD'
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Project Board</title>
<style>
:root { color-scheme: light dark; }
* { box-sizing: border-box; }
body {
  margin: 0; padding: 1.5rem;
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  line-height: 1.5; color: #1b1f24; background: #ffffff;
}
main { max-width: 60rem; margin: 0 auto; }
h1 { font-size: 1.6rem; margin: 0 0 .25rem; }
h2 { font-size: 1.2rem; margin: 1.75rem 0 .5rem; border-bottom: 1px solid #d5dae0; padding-bottom: .25rem; }
h3 { font-size: 1.05rem; margin: 1rem 0 .25rem; }
h4 { font-size: .95rem; margin: .75rem 0 .25rem; color: #444c56; }
p { margin: .25rem 0; }
.meta { color: #57606a; font-size: .9rem; }
.prov { color: #6e7781; font-size: .8rem; }
a.ref { font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace; font-size: .85rem; color: #0757ba; text-decoration: none; }
a.ref:hover { text-decoration: underline; }
ul.issues, ol.issues, ul.gatelist, ul.declist { margin: .25rem 0 .5rem; padding-left: 1.25rem; }
li.issue, li.gateitem, li.decitem { margin: .2rem 0; }
.title { color: #24292f; }
.goal { color: #444c56; font-style: italic; }
.pnote, .reason { color: #57606a; font-size: .9rem; }
.gate, .blockedby { color: #6e7781; font-size: .82rem; }
.phase { margin: .25rem 0 .5rem; padding-left: .5rem; border-left: 3px solid #e4e8ec; }
.plan { margin: .5rem 0 1rem; }
.tier, .state, .status {
  display: inline-block; padding: 0 .4rem; border-radius: .6rem;
  font-size: .72rem; font-weight: 600; vertical-align: middle; line-height: 1.5;
}
.tier { background: #eaeef2; color: #24292f; }
.t-P0 { background: #ffd7d5; color: #7a231e; }
.t-P1 { background: #ffe7c2; color: #7a4a12; }
.t-P2 { background: #eef3d4; color: #4d5a17; }
.t-P3 { background: #eaeef2; color: #57606a; }
.state { background: #eaeef2; color: #57606a; }
.s-open { background: #d3f3df; color: #1a5a34; }
.s-closed { background: #f0d7ff; color: #5a2a86; }
.s-unknown { background: #eaeef2; color: #57606a; }
.status { background: #eaeef2; color: #444c56; }
.st-active { background: #d3f3df; color: #1a5a34; }
.st-blocked { background: #ffd7d5; color: #7a231e; }
.st-paused { background: #ffe7c2; color: #7a4a12; }
.st-done { background: #eaeef2; color: #57606a; }
@media (prefers-color-scheme: dark) {
  body { color: #d7dde3; background: #14181c; }
  h2 { border-bottom-color: #2b3138; }
  h4 { color: #adbac7; }
  .meta { color: #9aa5b1; } .prov { color: #768390; }
  a.ref { color: #6cb6ff; }
  .title { color: #cdd9e5; }
  .goal { color: #adbac7; }
  .pnote, .reason { color: #9aa5b1; } .gate, .blockedby { color: #768390; }
  .phase { border-left-color: #2b3138; }
}
</style>
</head>
<body>
HEAD
printf '%s\n' "$body"
cat <<'TAIL'
</body>
</html>
TAIL
